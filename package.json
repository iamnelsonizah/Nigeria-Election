{
  "name": "nigeria-election-dashboard",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "npm.cmd --prefix frontend run dev -- --hostname 127.0.0.1 --port 3000",
    "start": "npm.cmd --prefix frontend run start -- --hostname 127.0.0.1 --port 3000",
    "build": "npm.cmd --prefix frontend run build",
    "lint": "npm.cmd --prefix frontend run lint",
    "api": ".venv\\Scripts\\python.exe -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000",
    "setup:api": "python -m venv .venv && .venv\\Scripts\\python.exe -m pip install -r requirements.txt"
  }
}
